{%- liquid
  assign sid = section.id
-%}
<style>
  #shopify-section-{{ sid }} {
    --tc-pt:               {{ section.settings.padding_top }}px;
    --tc-pb:               {{ section.settings.padding_bottom }}px;
    --tc-pt-m:             {{ section.settings.padding_top_mobile }}px;
    --tc-pb-m:             {{ section.settings.padding_bottom_mobile }}px;
    --tc-section-bg:       {{ section.settings.section_background }};
    --tc-gap:              {{ section.settings.grid_gap }}px;
    --tc-gap-m:            {{ section.settings.grid_gap_mobile }}px;
    --tc-radius:           {{ section.settings.card_border_radius }}px;
    --tc-overlay:          {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --tc-title-color:      {{ section.settings.title_color }};
    --tc-title-fs:         {{ section.settings.title_font_size_desktop }}px;
    --tc-title-fs-m:       {{ section.settings.title_font_size_mobile }}px;
    --tc-title-align:      {{ section.settings.title_alignment }};
    --tc-title-align-m:    {{ section.settings.title_alignment_mobile }};
    --tc-sub-color:        {{ section.settings.subtitle_color }};
    --tc-sub-fs:           {{ section.settings.subtitle_font_size_desktop }}px;
    --tc-sub-fs-m:         {{ section.settings.subtitle_font_size_mobile }}px;
    --tc-card-title-color: {{ section.settings.card_title_color }};
    --tc-card-title-fs:    {{ section.settings.card_title_font_size_desktop }}px;
    --tc-card-title-fs-m:  {{ section.settings.card_title_font_size_mobile }}px;
    --tc-link-color:       {{ section.settings.card_link_color }};
    --tc-link-fs:          {{ section.settings.card_link_font_size_desktop }}px;
    --tc-link-fs-m:        {{ section.settings.card_link_font_size_mobile }}px;
    --tc-hover-scale:      {{ section.settings.image_hover_scale | divided_by: 100.0 }};
  }
  .tc-section {
    background: var(--tc-section-bg);
    padding-top: var(--tc-pt);
    padding-bottom: var(--tc-pb);
  }
  .tc-container {
    max-width: {{ section.settings.container_max_width }}px;
    margin-inline: auto;
    padding-inline: {{ section.settings.container_padding }}px;
  }
  .tc-header {
    margin-bottom: {{ section.settings.header_bottom_gap }}px;
    text-align: var(--tc-title-align);
  }
  .tc-title {
    color: var(--tc-title-color);
    font-size: var(--tc-title-fs);
    font-weight: {{ section.settings.title_font_weight }};
    line-height: 1.15;
    margin: 0 0 6px;
    letter-spacing: {{ section.settings.title_letter_spacing }}em;
    {% if section.settings.title_uppercase %}text-transform: uppercase;{% endif %}
  }
  .tc-subtitle {
    color: var(--tc-sub-color);
    font-size: var(--tc-sub-fs);
    line-height: 1.5;
    margin: 0;
    font-weight: {{ section.settings.subtitle_font_weight }};
  }
  .tc-grid {
    display: grid;
    gap: var(--tc-gap);
  }
  .tc-grid--featured-left {
    grid-template-columns: {{ section.settings.hero_col_ratio }}fr {{ section.settings.small_col_ratio }}fr;
    grid-template-rows: repeat(2, 1fr);
  }
  .tc-grid--featured-left .tc-card:first-child {
    grid-row: 1 / span 2;
  }
  .tc-grid--equal {
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
  }
  .tc-grid--featured-right {
    grid-template-columns: {{ section.settings.small_col_ratio }}fr {{ section.settings.hero_col_ratio }}fr;
    grid-template-rows: repeat(2, 1fr);
  }
  .tc-grid--featured-right .tc-card:last-child {
    grid-row: 1 / span 2;
  }
  .tc-card {
    position: relative;
    border-radius: var(--tc-radius);
    overflow: hidden;
    min-height: {{ section.settings.card_min_height }}px;
  }
  .tc-card-inner {
    display: block;
    width: 100%;
    height: 100%;
    position: relative;
    text-decoration: none;
    color: inherit;
  }
  .tc-image-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }
  .tc-image-wrap img,
  .tc-image-wrap svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform {{ section.settings.hover_transition_duration }}ms ease;
    will-change: transform;
  }
  .tc-card-inner:hover .tc-image-wrap img {
    transform: scale(var(--tc-hover-scale));
  }
  .tc-placeholder .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .tc-overlay {
    position: absolute;
    inset: 0;
    background: {{ section.settings.overlay_color }};
    opacity: var(--tc-overlay);
    transition: opacity {{ section.settings.hover_transition_duration }}ms ease;
    pointer-events: none;
  }

  {% if section.settings.overlay_increase_on_hover %}
  .tc-card-inner:hover .tc-overlay {
    opacity: calc(var(--tc-overlay) + 0.15);
  }
  {% endif %}

  .tc-overlay-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      {{ section.settings.gradient_overlay_color }} 0%,
      transparent {{ section.settings.gradient_overlay_stop }}%
    );
    pointer-events: none;
  }

  .tc-card-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: {{ section.settings.content_vertical_align }};
    align-items: {{ section.settings.content_horizontal_align }};
    padding: {{ section.settings.card_content_padding }}px;
    text-align: {{ section.settings.card_text_align }};
    gap: 4px;
  }

  .tc-card-title {
    color: var(--tc-card-title-color);
    font-size: var(--tc-card-title-fs);
    font-weight: {{ section.settings.card_title_font_weight }};
    line-height: 1.2;
    margin: 0;
    text-shadow: {{ section.settings.text_shadow }};
    letter-spacing: {{ section.settings.card_title_letter_spacing }}em;
    {% if section.settings.card_title_uppercase %}text-transform: uppercase;{% endif %}
  }

  .tc-card-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    color: var(--tc-link-color);
    font-size: var(--tc-link-fs);
    font-weight: {{ section.settings.card_link_font_weight }};
    text-decoration: {{ section.settings.card_link_decoration }};
    transition: gap 200ms ease, opacity 200ms ease;
    margin: 0;
  }

  .tc-card-inner:hover .tc-card-link {
    gap: 9px;
    opacity: 0.9;
  }

  .tc-card-link svg {
    width: 14px;
    height: 14px;
    fill: currentColor;
    flex-shrink: 0;
  }

  .tc-badge {
    position: absolute;
    top: {{ section.settings.badge_top }}px;
    {% if section.settings.badge_position == 'top-left' %}
      left: {{ section.settings.badge_side }}px;
    {% else %}
      right: {{ section.settings.badge_side }}px;
    {% endif %}
    background: {{ section.settings.badge_bg }};
    color: {{ section.settings.badge_color }};
    font-size: 11px;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    pointer-events: none;
    z-index: 3;
  }

  .tc-grid--featured-left .tc-card:not(:first-child),
  .tc-grid--featured-right .tc-card:not(:last-child) {
    aspect-ratio: {{ section.settings.small_card_aspect_ratio }};
  }

  @media (max-width: 989px) {
    .tc-section {
      padding-top: var(--tc-pt-m);
      padding-bottom: var(--tc-pb-m);
    }

    .tc-container {
      padding-inline: {{ section.settings.container_padding_mobile }}px;
    }

    .tc-header {
      text-align: var(--tc-title-align-m);
      margin-bottom: {{ section.settings.header_bottom_gap_mobile }}px;
    }

    .tc-title    { font-size: var(--tc-title-fs-m); }
    .tc-subtitle { font-size: var(--tc-sub-fs-m); }
    .tc-card-title { font-size: var(--tc-card-title-fs-m); }
    .tc-card-link  { font-size: var(--tc-link-fs-m); }

    .tc-grid { gap: var(--tc-gap-m); }

    {% if section.settings.mobile_layout == 'single-col' %}
    .tc-grid--featured-left,
    .tc-grid--featured-right,
    .tc-grid--equal {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
    }
    .tc-grid--featured-left .tc-card:first-child,
    .tc-grid--featured-right .tc-card:last-child {
      grid-row: auto;
    }
    .tc-card {
      min-height: {{ section.settings.card_min_height_mobile }}px;
      aspect-ratio: unset;
    }
    {% endif %}

    {% if section.settings.mobile_layout == 'two-col' %}
    .tc-grid--featured-left,
    .tc-grid--featured-right,
    .tc-grid--equal {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: auto;
    }
    .tc-grid--featured-left .tc-card:first-child,
    .tc-grid--featured-right .tc-card:last-child {
      grid-row: auto;
      grid-column: 1 / -1;
    }
    .tc-card {
      min-height: {{ section.settings.card_min_height_mobile }}px;
      aspect-ratio: unset;
    }
    {% endif %}

    {% if section.settings.mobile_layout == 'slider' %}
    .tc-grid--featured-left,
    .tc-grid--featured-right,
    .tc-grid--equal {
      grid-template-columns: repeat({{ section.settings.mobile_slides_visible }}, {{ section.settings.mobile_card_width }}px);
      grid-template-rows: auto;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .tc-grid::-webkit-scrollbar { display: none; }
    .tc-grid--featured-left .tc-card:first-child,
    .tc-grid--featured-right .tc-card:last-child {
      grid-row: auto;
      grid-column: auto;
    }
    .tc-card {
      min-height: {{ section.settings.card_min_height_mobile }}px;
      scroll-snap-align: start;
      aspect-ratio: unset;
    }
    {% endif %}

    .tc-card-content {
      padding: {{ section.settings.card_content_padding_mobile }}px;
    }
  }

  @media (max-width: 479px) {
    .tc-card-title {
      font-size: calc(var(--tc-card-title-fs-m) - 2px);
    }
  }
</style>

<section
  id="tc-{{ sid }}"
  class="tc-section"
  aria-label="{{ section.settings.title | escape }}"
>
  <div class="tc-container">

    {%- unless section.settings.title == blank and section.settings.subtitle == blank -%}
      <div class="tc-header">
        {%- unless section.settings.title == blank -%}
          <{{ section.settings.title_tag }} class="tc-title">
            {{- section.settings.title -}}
          </{{ section.settings.title_tag }}>
        {%- endunless -%}
        {%- unless section.settings.subtitle == blank -%}
          <p class="tc-subtitle">{{ section.settings.subtitle }}</p>
        {%- endunless -%}
      </div>
    {%- endunless -%}

    {%- if section.blocks.size > 0 -%}
      <div class="tc-grid tc-grid--{{ section.settings.layout_style }}">

        {%- for block in section.blocks -%}
          {%- liquid
            assign is_hero = false
            if section.settings.layout_style == 'featured-left' and forloop.first
              assign is_hero = true
            endif
            if section.settings.layout_style == 'featured-right' and forloop.last
              assign is_hero = true
            endif
          -%}
          <div
            class="tc-card{% if is_hero %} tc-card--hero{% endif %}"
            style="
              {%- if block.settings.card_bg != blank -%}background:{{ block.settings.card_bg }};{%- endif -%}
              {%- if block.settings.custom_min_height > 0 -%}min-height:{{ block.settings.custom_min_height }}px;{%- endif -%}
            "
            {{ block.shopify_attributes }}
          >
            <a
              class="tc-card-inner"
              href="{{ block.settings.link | default: '#' }}"
            >

              <div class="tc-image-wrap{% if block.settings.image == blank %} tc-placeholder{% endif %}">
                {%- if block.settings.image != blank -%}
                  {%- assign img_alt = block.settings.image.alt | default: block.settings.title | escape -%}
                  {%- if forloop.index <= 2 -%}
                    {%- assign fetch_prio = 'high' -%}
                  {%- else -%}
                    {%- assign fetch_prio = 'auto' -%}
                  {%- endif -%}
                  <img
                    src="{{ block.settings.image | image_url: width: 1200 }}"
                    srcset="
                      {{ block.settings.image | image_url: width: 400 }} 400w,
                      {{ block.settings.image | image_url: width: 600 }} 600w,
                      {{ block.settings.image | image_url: width: 800 }} 800w,
                      {{ block.settings.image | image_url: width: 1000 }} 1000w,
                      {{ block.settings.image | image_url: width: 1200 }} 1200w
                    "
                    sizes="(max-width: 989px) 50vw, 33vw"
                    alt="{{ img_alt }}"
                    loading="lazy"
                    fetchpriority="{{ fetch_prio }}"
                    width="{{ block.settings.image.width }}"
                    height="{{ block.settings.image.height }}"
                  >
                {%- else -%}
                  {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>

              <div class="tc-overlay" role="presentation"></div>

              {%- if section.settings.show_gradient_overlay -%}
                <div class="tc-overlay-gradient" role="presentation"></div>
              {%- endif -%}

              {%- if block.settings.badge_text != blank -%}
                <span class="tc-badge">{{ block.settings.badge_text }}</span>
              {%- endif -%}

              <div class="tc-card-content">
                {%- unless block.settings.title == blank -%}
                  <p class="tc-card-title"
                    style="
                      {%- if block.settings.card_title_color_override != 'rgba(0,0,0,0)' and block.settings.card_title_color_override != blank -%}color:{{ block.settings.card_title_color_override }};{%- endif -%}
                      {%- if block.settings.card_title_font_size_override > 0 -%}font-size:{{ block.settings.card_title_font_size_override }}px;{%- endif -%}
                    "
                  >
                    {{- block.settings.title -}}
                  </p>
                {%- endunless -%}

                {%- unless block.settings.link_label == blank -%}
                  <span class="tc-card-link"
                    style="
                      {%- if block.settings.card_link_color_override != 'rgba(0,0,0,0)' and block.settings.card_link_color_override != blank -%}color:{{ block.settings.card_link_color_override }};{%- endif -%}
                    "
                  >
                    {{- block.settings.link_label -}}
                    {%- if section.settings.show_link_arrow -%}
                      <svg viewBox="0 0 20 20" aria-hidden="true">
                        <path d="M17.707 9.293l-5-5a1 1 0 00-1.414 1.414L14.586 9H3a1 1 0 000 2h11.586l-3.293 3.293a1 1 0 101.414 1.414l5-5a1 1 0 000-1.414z"/>
                      </svg>
                    {%- endif -%}
                  </span>
                {%- endunless -%}
              </div>

            </a>
          </div>
        {%- endfor -%}

      </div>

    {%- else -%}

      <div class="tc-grid tc-grid--featured-left">
        {%- for i in (1..5) -%}
          <div class="tc-card" style="min-height:{{ section.settings.card_min_height }}px;">
            <div class="tc-card-inner">
              <div class="tc-image-wrap tc-placeholder">
                {{ 'collection-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
              <div class="tc-overlay"></div>
              <div class="tc-overlay-gradient"></div>
              <div class="tc-card-content">
                <p class="tc-card-title">Category Name</p>
                <span class="tc-card-link">
                  Shop now
                  <svg viewBox="0 0 20 20" aria-hidden="true">
                    <path d="M17.707 9.293l-5-5a1 1 0 00-1.414 1.414L14.586 9H3a1 1 0 000 2h11.586l-3.293 3.293a1 1 0 101.414 1.414l5-5a1 1 0 000-1.414z"/>
                  </svg>
                </span>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>

    {%- endif -%}

  </div>
</section>


{% schema %}
{
  "name": "Top Categories",
  "tag": "section",
  "class": "tc-section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Section Layout"
    },
    {
      "type": "select",
      "id": "layout_style",
      "label": "Layout Style",
      "options": [
        { "value": "featured-left",  "label": "Hero Left + 2x2 Right" },
        { "value": "featured-right", "label": "2x2 Left + Hero Right" },
        { "value": "equal",          "label": "Equal Grid" }
      ],
      "default": "featured-left"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns (Equal Grid only)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "hero_col_ratio",
      "label": "Hero Column Width (fr)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "small_col_ratio",
      "label": "Small Cards Column Width (fr)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "select",
      "id": "small_card_aspect_ratio",
      "label": "Small Card Aspect Ratio",
      "options": [
        { "value": "16/9", "label": "16:9 Wide" },
        { "value": "4/3",  "label": "4:3" },
        { "value": "3/2",  "label": "3:2" },
        { "value": "1/1",  "label": "1:1 Square" },
        { "value": "3/4",  "label": "3:4 Portrait" }
      ],
      "default": "4/3"
    },
    {
      "type": "range",
      "id": "card_min_height",
      "label": "Min Card Height Desktop (px)",
      "min": 150,
      "max": 700,
      "step": 10,
      "default": 300
    },
    {
      "type": "header",
      "content": "Container"
    },
    {
      "type": "range",
      "id": "container_max_width",
      "label": "Max Container Width (px)",
      "min": 900,
      "max": 1600,
      "step": 20,
      "default": 1400
    },
    {
      "type": "range",
      "id": "container_padding",
      "label": "Side Padding Desktop (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 20
    },
    {
      "type": "range",
      "id": "container_padding_mobile",
      "label": "Side Padding Mobile (px)",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 16
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top Desktop (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom Desktop (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top Mobile (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom Mobile (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 36
    },
    {
      "type": "header",
      "content": "Section Background"
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "Section Background Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Grid Gap"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Card Gap Desktop (px)",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 12
    },
    {
      "type": "range",
      "id": "grid_gap_mobile",
      "label": "Card Gap Mobile (px)",
      "min": 0,
      "max": 24,
      "step": 2,
      "default": 8
    },
    {
      "type": "header",
      "content": "Section Title"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Top Categories"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Section Subtitle",
    },
    {
      "type": "select",
      "id": "title_tag",
      "label": "Title HTML Tag",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "p",  "label": "Paragraph" }
      ],
      "default": "h2"
    },
    {
      "type": "range",
      "id": "header_bottom_gap",
      "label": "Header Gap Desktop (px)",
      "min": 8,
      "max": 60,
      "step": 4,
      "default": 24
    },
    {
      "type": "range",
      "id": "header_bottom_gap_mobile",
      "label": "Header Gap Mobile (px)",
      "min": 4,
      "max": 40,
      "step": 2,
      "default": 16
    },
    {
      "type": "header",
      "content": "Title Typography"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "title_font_size_desktop",
      "label": "Title Font Size Desktop (px)",
      "min": 14,
      "max": 72,
      "step": 1,
      "default": 28
    },
    {
      "type": "range",
      "id": "title_font_size_mobile",
      "label": "Title Font Size Mobile (px)",
      "min": 14,
      "max": 48,
      "step": 1,
      "default": 22
    },
    {
      "type": "select",
      "id": "title_font_weight",
      "label": "Title Font Weight",
      "options": [
        { "value": "400", "label": "Regular 400" },
        { "value": "500", "label": "Medium 500" },
        { "value": "600", "label": "Semi Bold 600" },
        { "value": "700", "label": "Bold 700" },
        { "value": "800", "label": "Extra Bold 800" }
      ],
      "default": "700"
    },
    {
      "type": "range",
      "id": "title_letter_spacing",
      "label": "Title Letter Spacing (em x100)",
      "min": -5,
      "max": 20,
      "step": 1,
      "default": 0,
      "info": "Value is divided by 100 automatically. e.g. 5 = 0.05em"
    },
    {
      "type": "checkbox",
      "id": "title_uppercase",
      "label": "Uppercase Title",
      "default": false
    },
    {
      "type": "select",
      "id": "title_alignment",
      "label": "Title Alignment Desktop",
      "options": [
