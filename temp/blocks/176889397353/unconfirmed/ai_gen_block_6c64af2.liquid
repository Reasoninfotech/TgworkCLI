{% doc %}
  @prompt
    A magazine-style editorial layout
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-editorial-layout-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-editorial-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    align-items: start;
  }

  .ai-editorial-featured-{{ ai_gen_id }} {
    grid-column: span 7;
    position: relative;
  }

  .ai-editorial-featured-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-editorial-featured-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 3 / 4;
    background-color: #f5f5f5;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-editorial-featured-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-editorial-sidebar-{{ ai_gen_id }} {
    grid-column: span 5;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_spacing }}px;
  }

  .ai-editorial-category-{{ ai_gen_id }} {
    font-family: {{ block.settings.type_heading_font.family }}, {{ block.settings.type_heading_font.fallback_families }};
    font-weight: {{ block.settings.type_heading_font.weight }};
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: {{ block.settings.category_color }};
    margin: 0 0 {{ block.settings.content_spacing | divided_by: 2 }}px;
  }

  .ai-editorial-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.type_heading_font.family }}, {{ block.settings.type_heading_font.fallback_families }};
    font-weight: {{ block.settings.type_heading_font.weight }};
    font-size: {{ block.settings.title_size }}px;
    line-height: 1.1;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.content_spacing }}px;
  }

  .ai-editorial-excerpt-{{ ai_gen_id }} {
    font-family: {{ block.settings.type_body_font.family }}, {{ block.settings.type_body_font.fallback_families }};
    font-weight: {{ block.settings.type_body_font.weight }};
    font-size: {{ block.settings.body_size }}px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
    margin: 0 0 {{ block.settings.content_spacing }}px;
  }

  .ai-editorial-meta-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 16px;
    font-family: {{ block.settings.type_body_font.family }}, {{ block.settings.type_body_font.fallback_families }};
    font-size: 13px;
    color: {{ block.settings.text_color }};
    opacity: 0.6;
    margin: 0 0 {{ block.settings.content_spacing }}px;
  }

  .ai-editorial-meta-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .ai-editorial-divider-{{ ai_gen_id }} {
    width: 60px;
    height: 2px;
    background-color: {{ block.settings.text_color }};
    margin: {{ block.settings.content_spacing }}px 0;
  }

  .ai-editorial-cta-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-family: {{ block.settings.type_body_font.family }}, {{ block.settings.type_body_font.fallback_families }};
    font-weight: 500;
    font-size: 14px;
    transition: all 0.3s ease;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
  }

  .ai-editorial-cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-editorial-secondary-grid-{{ ai_gen_id }} {
    grid-column: span 12;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-top: {{ block.settings.grid_gap | times: 2 }}px;
  }

  .ai-editorial-card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_spacing | divided_by: 2 }}px;
  }

  .ai-editorial-card-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-editorial-card-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-color: #f5f5f5;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-editorial-card-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-editorial-card-category-{{ ai_gen_id }} {
    font-family: {{ block.settings.type_heading_font.family }}, {{ block.settings.type_heading_font.fallback_families }};
    font-weight: {{ block.settings.type_heading_font.weight }};
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: {{ block.settings.category_color }};
    margin: 0;
  }

  .ai-editorial-card-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.type_heading_font.family }}, {{ block.settings.type_heading_font.fallback_families }};
    font-weight: {{ block.settings.type_heading_font.weight }};
    font-size: {{ block.settings.card_title_size }}px;
    line-height: 1.3;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-editorial-card-meta-{{ ai_gen_id }} {
    font-family: {{ block.settings.type_body_font.family }}, {{ block.settings.type_body_font.fallback_families }};
    font-size: 12px;
    color: {{ block.settings.text_color }};
    opacity: 0.6;
    margin: 0;
  }

  .ai-editorial-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 8px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 989px) {
    .ai-editorial-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.grid_gap | times: 1.5 }}px;
    }

    .ai-editorial-featured-{{ ai_gen_id }},
    .ai-editorial-sidebar-{{ ai_gen_id }} {
      grid-column: span 1;
    }

    .ai-editorial-secondary-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.grid_gap | times: 1.5 }}px;
    }

    .ai-editorial-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-editorial-layout-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.6 }}px 0;
    }

    .ai-editorial-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.6 }}px;
    }

    .ai-editorial-card-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.card_title_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-editorial-layout-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-editorial-grid-{{ ai_gen_id }}">
    <div class="ai-editorial-featured-{{ ai_gen_id }}">
      {% if block.settings.featured_image %}
        <img
          src="{{ block.settings.featured_image | image_url: width: 1400 }}"
          alt="{{ block.settings.featured_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.featured_image.width }}"
          height="{{ block.settings.featured_image.height }}"
          class="ai-editorial-featured-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-editorial-featured-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
          <div class="ai-editorial-empty-state-{{ ai_gen_id }}">
            Add a featured image
          </div>
        </div>
      {% endif %}
    </div>

    <div class="ai-editorial-sidebar-{{ ai_gen_id }}">
      {% if block.settings.category != blank %}
        <div class="ai-editorial-category-{{ ai_gen_id }}">{{ block.settings.category }}</div>
      {% endif %}

      {% if block.settings.title != blank %}
        <h2 class="ai-editorial-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}

      {% if block.settings.excerpt != blank %}
        <div class="ai-editorial-excerpt-{{ ai_gen_id }}">{{ block.settings.excerpt }}</div>
      {% endif %}

      <div class="ai-editorial-meta-{{ ai_gen_id }}">
        {% if block.settings.author != blank %}
          <div class="ai-editorial-meta-item-{{ ai_gen_id }}">
            {{ block.settings.author }}
          </div>
        {% endif %}
        {% if block.settings.date != blank %}
          <div class="ai-editorial-meta-item-{{ ai_gen_id }}">
            {{ block.settings.date }}
          </div>
        {% endif %}
        {% if block.settings.read_time != blank %}
          <div class="ai-editorial-meta-item-{{ ai_gen_id }}">
            {{ block.settings.read_time }}
          </div>
        {% endif %}
      </div>

      {% if block.settings.show_divider %}
        <div class="ai-editorial-divider-{{ ai_gen_id }}"></div>
      {% endif %}

      {% if block.settings.button_text != blank %}
        <div>
          <a href="{{ block.settings.button_link }}" class="ai-editorial-cta-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      {% endif %}
    </div>

    {% if block.settings.show_secondary_articles %}
      <div class="ai-editorial-secondary-grid-{{ ai_gen_id }}">
        {% for i in (1..3) %}
          {% liquid
            assign image_key = 'card_' | append: i | append: '_image'
            assign category_key = 'card_' | append: i | append: '_category'
            assign title_key = 'card_' | append: i | append: '_title'
            assign date_key = 'card_' | append: i | append: '_date'

            assign card_image = block.settings[image_key]
            assign card_category = block.settings[category_key]
            assign card_title = block.settings[title_key]
            assign card_date = block.settings[date_key]
          %}

          <div class="ai-editorial-card-{{ ai_gen_id }}">
            {% if card_image %}
              <img
                src="{{ card_image | image_url: width: 600 }}"
                alt="{{ card_image.alt | escape }}"
                loading="lazy"
                width="{{ card_image.width }}"
                height="{{ card_image.height }}"
                class="ai-editorial-card-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-editorial-card-placeholder-{{ ai_gen_id }}">
                {{ 'collection-apparel-1' | placeholder_svg_tag }}
              </div>
            {% endif %}

            {% if card_category != blank %}
              <div class="ai-editorial-card-category-{{ ai_gen_id }}">{{ card_category }}</div>
            {% endif %}

            {% if card_title != blank %}
              <h3 class="ai-editorial-card-title-{{ ai_gen_id }}">{{ card_title }}</h3>
            {% endif %}

            {% if card_date != blank %}
              <div class="ai-editorial-card-meta-{{ ai_gen_id }}">{{ card_date }}</div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Magazine editorial",
  "settings": [
    {
      "type": "header",
      "content": "Featured article"
    },
    {
      "type": "image_picker",
      "id": "featured_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "category",
      "label": "Category",
      "default": "Featured"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Title",
      "default": "The Art of Modern Design"
    },
    {
      "type": "textarea",
      "id": "excerpt",
      "label": "Excerpt",
      "default": "Exploring the intersection of form and function in contemporary aesthetics, where minimalism meets bold expression."
    },
    {
      "type": "text",
      "id": "author",
      "label": "Author",
      "default": "Editorial Team"
    },
    {
      "type": "text",
      "id": "date",
      "label": "Date",
      "default": "June 23, 2026"
    },
    {
      "type": "text",
      "id": "read_time",
      "label": "Read time",
      "default": "5 min read"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show divider",
      "default": true
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Read article"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Secondary articles"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_articles",
      "label": "Show secondary articles",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "card_1_image",
      "label": "Article 1 image"
    },
    {
      "type": "text",
      "id": "card_1_category",
      "label": "Article 1 category",
      "default": "Design"
    },
    {
      "type": "text",
      "id": "card_1_title",
      "label": "Article 1 title",
      "default": "Minimalist Spaces"
    },
    {
      "type": "text",
      "id": "card_1_date",
      "label": "Article 1 date",
      "default": "June 20, 2026"
    },
    {
      "type": "image_picker",
      "id": "card_2_image",
      "label": "Article 2 image"
    },
    {
      "type": "text",
      "id": "card_2_category",
      "label": "Article 2 category",
      "default": "Culture"
    },
    {
      "type": "text",
      "id": "card_2_title",
      "label": "Article 2 title",
      "default": "Creative Process"
    },
    {
      "type": "text",
      "id": "card_2_date",
      "label": "Article 2 date",
      "default": "June 18, 2026"
    },
    {
      "type": "image_picker",
      "id": "card_3_image",
      "label": "Article 3 image"
    },
    {
      "type": "text",
      "id": "card_3_category",
      "label": "Article 3 category",
      "default": "Lifestyle"
    },
    {
      "type": "text",
      "id": "card_3_title",
      "label": "Article 3 title",
      "default": "Sustainable Living"
    },
    {
      "type": "text",
      "id": "card_3_date",
      "label": "Article 3 date",
      "default": "June 15, 2026"
    },
    {
      "type": "header",
