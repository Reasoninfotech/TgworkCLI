{% comment %}
  ============================================================
  Section: Reviews Masonry — Horizon Theme Compatible
  File: sections/reviews-masonry.liquid
  ============================================================
{% endcomment %}

{%- liquid
  assign section_id    = 'reviews-masonry-' | append: section.id
  assign bg_color      = section.settings.bg_color
  assign title_text    = section.settings.title
  assign subtitle_text = section.settings.subtitle
  assign badge_text    = section.settings.badge_text
  assign show_badge    = section.settings.show_badge
  assign star_color    = section.settings.star_color
  assign title_color   = section.settings.title_color
  assign subtitle_color = section.settings.subtitle_color

  assign title_size_desk   = section.settings.title_size_desktop
  assign title_size_mob    = section.settings.title_size_mobile
  assign subtitle_size_desk = section.settings.subtitle_size_desktop
  assign subtitle_size_mob  = section.settings.subtitle_size_mobile

  assign cols_desktop = section.settings.columns_desktop
  assign cols_tablet  = section.settings.columns_tablet
  assign cols_mobile  = section.settings.columns_mobile
  assign gap_desktop  = section.settings.gap_desktop
  assign gap_mobile   = section.settings.gap_mobile

  assign card_bg          = section.settings.card_bg_color
  assign card_radius      = section.settings.card_border_radius
  assign card_shadow      = section.settings.card_shadow
  assign card_border      = section.settings.card_border_enable
  assign card_border_color = section.settings.card_border_color

  assign reviewer_color    = section.settings.reviewer_name_color
  assign review_title_color = section.settings.review_title_color
  assign review_text_color  = section.settings.review_text_color
  assign verified_color     = section.settings.verified_color

  assign reviewer_size_desk = section.settings.reviewer_name_size_desktop
  assign reviewer_size_mob  = section.settings.reviewer_name_size_mobile
  assign review_title_size_desk = section.settings.review_title_size_desktop
  assign review_title_size_mob  = section.settings.review_title_size_mobile
  assign review_text_size_desk  = section.settings.review_text_size_desktop
  assign review_text_size_mob   = section.settings.review_text_size_mobile

  assign show_cta      = section.settings.show_cta_button
  assign cta_label     = section.settings.cta_label
  assign cta_url       = section.settings.cta_url
  assign cta_bg        = section.settings.cta_bg_color
  assign cta_text_col  = section.settings.cta_text_color
  assign cta_radius    = section.settings.cta_border_radius

  assign pt_desk = section.settings.padding_top_desktop
  assign pb_desk = section.settings.padding_bottom_desktop
  assign pt_mob  = section.settings.padding_top_mobile
  assign pb_mob  = section.settings.padding_bottom_mobile
-%}

<style>
  /* ── Root Variables ── */
  #{{ section_id }} {
    --rm-bg:               {{ bg_color }};
    --rm-star:             {{ star_color }};
    --rm-title-color:      {{ title_color }};
    --rm-subtitle-color:   {{ subtitle_color }};
    --rm-card-bg:          {{ card_bg }};
    --rm-card-radius:      {{ card_radius }}px;
    --rm-card-shadow:      {% if card_shadow == 'none' %}none{% elsif card_shadow == 'soft' %}0 2px 16px rgba(0,0,0,.07){% elsif card_shadow == 'medium' %}0 4px 28px rgba(0,0,0,.12){% else %}0 8px 48px rgba(0,0,0,.18){% endif %};
    --rm-card-border:      {% if card_border %}1px solid {{ card_border_color }}{% else %}none{% endif %};
    --rm-reviewer:         {{ reviewer_color }};
    --rm-review-title:     {{ review_title_color }};
    --rm-review-text:      {{ review_text_color }};
    --rm-verified:         {{ verified_color }};
    --rm-cta-bg:           {{ cta_bg }};
    --rm-cta-text:         {{ cta_text_col }};
    --rm-cta-radius:       {{ cta_radius }}px;
    --rm-gap-desktop:      {{ gap_desktop }}px;
    --rm-gap-mobile:       {{ gap_mobile }}px;
    --rm-cols-desktop:     {{ cols_desktop }};
    --rm-cols-tablet:      {{ cols_tablet }};
    --rm-cols-mobile:      {{ cols_mobile }};

    /* Typography – Desktop */
    --rm-title-size:        {{ title_size_desk }}px;
    --rm-subtitle-size:     {{ subtitle_size_desk }}px;
    --rm-reviewer-size:     {{ reviewer_size_desk }}px;
    --rm-review-title-size: {{ review_title_size_desk }}px;
    --rm-review-text-size:  {{ review_text_size_desk }}px;

    background-color: var(--rm-bg);
    padding-top:    {{ pt_desk }}px;
    padding-bottom: {{ pb_desk }}px;
  }

  /* ── Mobile overrides ── */
  @media (max-width: 749px) {
    #{{ section_id }} {
      --rm-title-size:        {{ title_size_mob }}px;
      --rm-subtitle-size:     {{ subtitle_size_mob }}px;
      --rm-reviewer-size:     {{ reviewer_size_mob }}px;
      --rm-review-title-size: {{ review_title_size_mob }}px;
      --rm-review-text-size:  {{ review_text_size_mob }}px;
      padding-top:    {{ pt_mob }}px;
      padding-bottom: {{ pb_mob }}px;
    }
  }

  /* ── Header ── */
  .rm__header {
    text-align: center;
    margin-bottom: 40px;
  }
  .rm__badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: color-mix(in srgb, var(--rm-star) 15%, transparent);
    border: 1px solid color-mix(in srgb, var(--rm-star) 40%, transparent);
    color: color-mix(in srgb, var(--rm-star) 80%, #000 20%);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: .04em;
    padding: 5px 14px;
    border-radius: 100px;
    margin-bottom: 16px;
  }
  .rm__stars {
    display: flex;
    justify-content: center;
    gap: 4px;
    margin-bottom: 14px;
  }
  .rm__stars svg { width: 28px; height: 28px; fill: var(--rm-star); }
  .rm__title {
    font-size: var(--rm-title-size);
    font-weight: 700;
    color: var(--rm-title-color);
    margin: 0 0 10px;
    line-height: 1.15;
  }
  .rm__subtitle {
    font-size: var(--rm-subtitle-size);
    color: var(--rm-subtitle-color);
    margin: 0;
    line-height: 1.6;
  }

  /* ── Masonry Grid ── */
  .rm__grid {
    column-count: var(--rm-cols-desktop);
    column-gap: var(--rm-gap-desktop);
  }
  @media (max-width: 989px) {
    .rm__grid { column-count: var(--rm-cols-tablet); }
  }
  @media (max-width: 749px) {
    .rm__grid {
      column-count: var(--rm-cols-mobile);
      column-gap: var(--rm-gap-mobile);
    }
  }

  /* ── Card ── */
  .rm__card {
    background:    var(--rm-card-bg);
    border-radius: var(--rm-card-radius);
    box-shadow:    var(--rm-card-shadow);
    border:        var(--rm-card-border);
    padding: 22px;
    break-inside:  avoid;
    margin-bottom: var(--rm-gap-desktop);
    transition: transform .25s ease, box-shadow .25s ease;
    display: inline-block; /* Masonry requirement */
    width: 100%;
    box-sizing: border-box;
  }
  @media (max-width: 749px) {
    .rm__card { margin-bottom: var(--rm-gap-mobile); }
  }
  .rm__card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(0,0,0,.15);
  }

  /* ── Card – Reviewer Row ── */
  .rm__card-head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }
  .rm__avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 15px;
    font-weight: 700;
    color: #fff;
    flex-shrink: 0;
    overflow: hidden;
  }
  .rm__avatar img { width: 100%; height: 100%; object-fit: cover; }
  .rm__reviewer-info { flex: 1; min-width: 0; }
  .rm__reviewer-name {
    font-size: var(--rm-reviewer-size);
    font-weight: 700;
    color: var(--rm-reviewer);
    margin: 0 0 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .rm__verified {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    color: var(--rm-verified);
    font-weight: 500;
  }
  .rm__verified svg { width: 12px; height: 12px; fill: var(--rm-verified); }

  /* ── Card – Stars ── */
  .rm__card-stars {
    display: flex;
    gap: 2px;
    margin-bottom: 8px;
  }
  .rm__card-stars svg { width: 14px; height: 14px; fill: var(--rm-star); }
  .rm__card-stars svg.empty { fill: #ddd; }

  /* ── Card – Body ── */
  .rm__review-title {
    font-size: var(--rm-review-title-size);
    font-weight: 700;
    color: var(--rm-review-title);
    margin: 0 0 8px;
    line-height: 1.3;
  }
  .rm__review-text {
    font-size: var(--rm-review-text-size);
    color: var(--rm-review-text);
    line-height: 1.65;
    margin: 0 0 12px;
  }
  .rm__review-image {
    width: 100%;
    border-radius: calc(var(--rm-card-radius) - 6px);
    object-fit: cover;
    display: block;
    margin-top: 10px;
  }

  /* ── CTA ── */
  .rm__cta-wrap {
    text-align: center;
    margin-top: 48px;
  }
  .rm__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--rm-cta-bg);
    color: var(--rm-cta-text);
    border-radius: var(--rm-cta-radius);
    padding: 14px 36px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: .02em;
    transition: opacity .2s, transform .2s;
    border: none;
    cursor: pointer;
  }
  .rm__cta:hover { opacity: .88; transform: translateY(-1px); }

  /* ── Avatar Color Palette ── */
  .rm__avatar--0  { background: #e05d5d; }
  .rm__avatar--1  { background: #e08f3a; }
  .rm__avatar--2  { background: #5aae6e; }
  .rm__avatar--3  { background: #3a87c8; }
  .rm__avatar--4  { background: #8e5dc8; }
  .rm__avatar--5  { background: #c85d9a; }
  .rm__avatar--6  { background: #3abfc8; }
  .rm__avatar--7  { background: #c8b83a; }
  .rm__avatar--8  { background: #c8603a; }
  .rm__avatar--9  { background: #5d8ec8; }
</style>

<section
  id="{{ section_id }}"
  class="reviews-masonry section--page-width"
  aria-label="{{ title_text | escape }}"
>
  <div class="page-width">

    {%- comment %} ── Header ── {%- endcomment %}
    <div class="rm__header">
      {%- if show_badge and badge_text != blank -%}
        <div class="rm__badge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z" fill="currentColor"/>
          </svg>
          {{ badge_text }}
        </div>
      {%- endif -%}

      <div class="rm__stars" aria-hidden="true">
        {%- for i in (1..5) -%}
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/>
          </svg>
        {%- endfor -%}
      </div>

      {%- if title_text != blank -%}
        <h2 class="rm__title">{{ title_text }}</h2>
      {%- endif -%}
      {%- if subtitle_text != blank -%}
        <p class="rm__subtitle">{{ subtitle_text }}</p>
      {%- endif -%}
    </div>

    {%- comment %} ── Masonry Grid ── {%- endcomment %}
    {%- if section.blocks.size > 0 -%}
      <div class="rm__grid" id="rm-grid-{{ section.id }}" data-masonry='{"itemSelector":".rm__card","percentPosition":true}'>
        {%- for block in section.blocks -%}
          {%- liquid
            assign rating          = block.settings.star_rating | plus: 0
            assign initials        = block.settings.reviewer_name | slice: 0, 1 | upcase
            assign color_idx       = forloop.index0 | modulo: 10
            assign avatar_alt      = block.settings.reviewer_name | escape
            assign review_img_alt  = block.settings.review_title | escape
          -%}
          <div
            class="rm__card"
            {{ block.shopify_attributes }}
          >
            {%- comment %} Reviewer Row {%- endcomment %}
            <div class="rm__card-head">
              <div class="rm__avatar rm__avatar--{{ color_idx }}" aria-hidden="true">
                {%- if block.settings.avatar_image != blank -%}
                  {{ block.settings.avatar_image | image_url: width: 80 | image_tag: loading: 'lazy', alt: avatar_alt, width: 80, height: 80 }}
                {%- else -%}
                  {{ initials }}
                {%- endif -%}
              </div>
              <div class="rm__reviewer-info">
                <p class="rm__reviewer-name">{{ block.settings.reviewer_name }}</p>
                {%- if block.settings.show_verified -%}
                  <span class="rm__verified">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                      <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    {{ block.settings.verified_label | default: 'Verified buyer' }}
                  </span>
                {%- endif -%}
              </div>
            </div>

            {%- comment %} Stars {%- endcomment %}
            <div class="rm__card-stars" aria-label="{{ rating }} out of 5 stars">
              {%- for i in (1..5) -%}
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" class="{% if i <= rating %}filled{% else %}empty{% endif %}">
                  <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/>
                </svg>
              {%- endfor -%}
            </div>

            {%- comment %} Review Title {%- endcomment %}
            {%- if block.settings.review_title != blank -%}
              <p class="rm__review-title">{{ block.settings.review_title }}</p>
            {%- endif -%}

            {%- comment %} Review Body {%- endcomment %}
            {%- if block.settings.review_text != blank -%}
              <div class="rm__review-text">{{ block.settings.review_text }}</div>
            {%- endif -%}

            {%- comment %} Review Image {%- endcomment %}
            {%- if block.settings.review_image != blank -%}
              {{ block.settings.review_image | image_url: width: 600 | image_tag: class: 'rm__review-image', loading: 'lazy', alt: review_img_alt, widths: '300,400,600' }}
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- else -%}
      {%- if request.design_mode -%}
        <p style="text-align:center;opacity:.5;padding:40px 0;">
          Add review blocks from the customizer to populate this section.
        </p>
      {%- endif -%}
    {%- endif -%}

    {%- comment %} ── CTA Button ── {%- endcomment %}
    {%- if show_cta and cta_label != blank -%}
      <div class="rm__cta-wrap">
        <a
          href="{{ cta_url | default: '#' }}"
          class="rm__cta"
          {% if cta_url == blank %}aria-disabled="true"{% endif %}
        >
          {{ cta_label }}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

{%- comment %} ── Masonry JS ── {%- endcomment %}
<script>
  (function () {
    var MASONRY_CDN = 'https://cdnjs.cloudflare.com/ajax/libs/masonry/4.2.2/masonry.pkgd.min.js';
    var gridId      = 'rm-grid-{{ section.id }}';

    function initMasonry() {
      var el = document.getElementById(gridId);
      if (!el) return;
      /* Wait for all images inside the grid to load */
      var imgs = el.querySelectorAll('img');
      var total = imgs.length;
      var loaded = 0;

      function run() {
        if (window.Masonry) {
          var msnry = new Masonry(el, {
            itemSelector: '.rm__card',
            percentPosition: true,
            transitionDuration: '0.3s'
          });
          /* Recalc on image load to fix collapsed items */
          imgs.forEach(function(img){
            if (img.complete) { msnry.layout(); }
            else { img.addEventListener('load', function(){ msnry.layout(); }); }
          });
        }
      }

      if (!window.Masonry) {
        var s = document.createElement('script');
        s.src = MASONRY_CDN;
        s.onload = run;
        document.head.appendChild(s);
      } else {
        run();
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initMasonry);
    } else {
      initMasonry();
    }

    /* Shopify Theme Editor: re-init on section/block changes */
    document.addEventListener('shopify:section:load',  function(e){ if (e.detail && e.detail.sectionId === '{{ section.id }}') initMasonry(); });
    document.addEventListener('shopify:block:select',  function(){ initMasonry(); });
    document.addEventListener('shopify:block:deselect',function(){ initMasonry(); });
  })();
</script>

{% schema %}
{
  "name": "Reviews Masonry",
  "tag": "section",
  "class": "reviews-masonry-section",
  "limit": 1,
  "settings": [

    {
      "type": "header",
      "content": "🏷️ Section Header"
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "Show Badge",
      "default": true
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "Trusted Reviews"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Join 320,000+ happy customers"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle / Description",
      "default": "Proudly engineered in Canada, Kala is committed to delivering medical grade quality products."
    },

    {
      "type": "header",
      "content": "🔤 Title Typography — Desktop"
    },
    {
      "type": "range",
      "id": "title_size_desktop",
      "label": "Title Font Size (Desktop)",
      "min": 20,
      "max": 72,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "subtitle_size_desktop",
      "label": "Subtitle Font Size (Desktop)",
      "min": 12,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 16
    },

    {
      "type": "header",
      "content": "📱 Title Typography — Mobile"
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "label": "Title Font Size (Mobile)",
      "min": 16,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "subtitle_size_mobile",
      "label": "Subtitle Font Size (Mobile)",
      "min": 12,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 14
    },

    {
      "type": "header",
      "content": "🎨 Header Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star Color",
      "default": "#f4a716"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle Color",
      "default": "#555555"
    },

    {
      "type": "header",
      "content": "📐 Layout — Columns"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns (Desktop ≥990px)",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "label": "Columns (Tablet 750–989px)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns (Mobile <750px)",
      "options": [
        { "value": "1", "label": "1 Column" },
        { "value": "2", "label": "2 Columns" }
      ],
      "default": "1"
    },
    {
      "type": "range",
      "id": "gap_desktop",
      "label": "Column Gap (Desktop)",
      "min": 4,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "label": "Column Gap (Mobile)",
      "min": 4,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    },

    {
      "type": "header",
      "content": "🃏 Card Style"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Card Border Radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "select",
      "id": "card_shadow",
      "label": "Card Shadow",
      "options": [
        { "value": "none",   "label": "None" },
        { "value": "soft",   "label": "Soft" },
        { "value": "medium", "label": "Medium" },
        { "value": "strong", "label": "Strong" }
      ],
      "default": "soft"
    },
    {
      "type": "checkbox",
      "id": "card_border_enable",
      "label": "Show Card Border",
      "default": false
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card Border Color",
      "default": "#e0e0e0"
    },

    {
      "type": "header",
      "content": "✍️ Review Card Typography — Desktop"
    },
    {
      "type": "range",
      "id": "reviewer_name_size_desktop",
      "label": "Reviewer Name Size (Desktop)",
      "min": 10,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "review_title_size_desktop",
      "label": "Review Title Size (Desktop)",
      "min": 10,
      "max": 24,
