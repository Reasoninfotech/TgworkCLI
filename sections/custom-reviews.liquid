{% style %}
.section-{{ section.id }} {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
}

.section-{{ section.id }} .heading {
  color: {{ section.settings.title_color }};
  font-size: {{ section.settings.title_size }}px;
  text-align: center;
}

.section-{{ section.id }} .subheading {
  color: {{ section.settings.text_color }};
  font-size: {{ section.settings.text_size }}px;
  text-align: center;
  margin-top: 10px;
}

@media(max-width: 768px){
  .section-{{ section.id }} .heading {
    font-size: {{ section.settings.title_size_mobile }}px;
  }
  .section-{{ section.id }} .subheading {
    font-size: {{ section.settings.text_size_mobile }}px;
  }
}

.masonry-grid {
  column-count: 4;
  column-gap: 20px;
  margin-top: 40px;
}

@media(max-width: 1200px){
  .masonry-grid { column-count: 3; }
}
@media(max-width: 768px){
  .masonry-grid { column-count: 2; }
}
@media(max-width: 480px){
  .masonry-grid { column-count: 1; }
}

.masonry-item {
  break-inside: avoid;
  background: #fff;
  border-radius: 12px;
  padding: 15px;
  margin-bottom: 20px;
  box-shadow: 0 4px 10px rgba(0,0,0,0.05);
}

.masonry-item img {
  width: 100%;
  border-radius: 8px;
  margin-top: 10px;
}

.review-name {
  font-weight: 600;
  margin-bottom: 5px;
}

.review-text {
  font-size: 14px;
}
{% endstyle %}

<div class="section-{{ section.id }}">
  <div class="section--page-width">

    {% if section.settings.title != blank %}
      <h2 class="heading">{{ section.settings.title }}</h2>
    {% endif %}

    {% if section.settings.content != blank %}
      <div class="subheading">{{ section.settings.content }}</div>
    {% endif %}

    <div class="masonry-grid" id="masonry-{{ section.id }}">
      {% for block in section.blocks %}
        <div class="masonry-item">
          
          <div class="review-name">{{ block.settings.name }}</div>

          <div class="review-text">
            {{ block.settings.text }}
          </div>

          {% if block.settings.image != blank %}
            <img src="{{ block.settings.image | image_url }}" loading="lazy">
          {% endif %}

        </div>
      {% endfor %}
    </div>

  </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function() {
  var grid = document.getElementById("masonry-{{ section.id }}");

  // Simple Masonry fallback (CSS column based)
  // If you want JS Masonry enhance:
  function applyMasonry() {
    var items = grid.querySelectorAll('.masonry-item');
    items.forEach(function(item){
      item.style.display = "inline-block";
      item.style.width = "100%";
    });
  }

  applyMasonry();
});
</script>

{% schema %}
{
  "name": "Testimonial Masonry",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Join 320,000+ happy customers"
    },
    {
      "type": "textarea",
      "id": "content",
      "label": "Content",
      "default": "Proudly engineered in Canada..."
    },

    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title Size Desktop",
      "min": 16,
      "max": 60,
      "step": 1,
      "default": 32
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "label": "Title Size Mobile",
      "min": 14,
      "max": 40,
      "step": 1,
      "default": 24
    },

    {
      "type": "color",
      "id": "text_color",
      "label": "Content Color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text Size Desktop",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "text_size_mobile",
      "label": "Text Size Mobile",
      "min": 12,
      "max": 20,
      "step": 1,
      "default": 14
    },

    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 40
    }
  ],

  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Customer Name",
          "default": "John Doe"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review Text",
          "default": "Amazing product!"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Review Image"
        }
      ]
    }
  ],

  "presets": [
    {
      "name": "Testimonial Masonry",
      "blocks": [
        { "type": "review" },
        { "type": "review" },
        { "type": "review" }
      ]
    }
  ]
}
{% endschema %}